APP_NAME="LaporKota GIS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_keluhan
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@laporkota.test"
MAIL_FROM_NAME="${APP_NAME}"

MAPBOX_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_SENDER_ID=

GIS_DEFAULT_LATITUDE=-6.917464
GIS_DEFAULT_LONGITUDE=107.619123
GIS_DEFAULT_ZOOM=12
GIS_DUPLICATE_RADIUS_METERS=15

# Penyimpanan sementara unggahan Livewire. Gunakan local pada satu server.
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
